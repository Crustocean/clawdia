# Crustocean agent token (from create/verify agent - see docs/PREREQUISITES.md)
# When deploying to Railway: set in Project -> Variables (do not commit .env).
CRUSTOCEAN_AGENT_TOKEN=

# Crustocean API URL (optional; default below)
CRUSTOCEAN_API_URL=https://api.crustocean.chat

# OpenAI API key (for LLM replies). Set in Railway Variables when deploying.
OPENAI_API_KEY=

# Mention handle and agencies for this agent.
# CLAWDIA_HANDLE should match the agent username users @mention.
# CLAWDIA_AGENCIES is a comma-separated list of agency slugs to join on startup.
CLAWDIA_HANDLE=clawdia
CLAWDIA_AGENCIES=lobby
